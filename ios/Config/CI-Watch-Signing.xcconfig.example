// Copy to `CI-Watch-Signing.xcconfig` for local manual App Store signing,
// or let CI generate it via scripts/ios-install-distribution-signing.sh.
//
// Applies only to the OpenZCineWatch target through OpenZCineWatch/Watch.xcconfig.

CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = Apple Distribution
PROVISIONING_PROFILE_SPECIFIER = OpenZCine_Watch_AppStore
