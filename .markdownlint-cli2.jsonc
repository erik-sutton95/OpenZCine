{
  // Rule overrides.
  "config": {
    "default": true,
    "MD013": false,
    "MD033": false,
    "MD041": false
  },
  // Don't lint proprietary dirs, internal planning artifacts (planning docs embed
  // nested code fences on purpose), or skill reference material (dense protocol
  // tables in their own compact format).
  "ignores": [
    "vendor/**",
    "ref/**",
    ".local/**",
    ".claude/skills/**",
    // graphify knowledge-graph output is regenerated locally; never committed.
    "graphify-out/**",
    // Worktree checkouts (agent sessions) are full repo copies — linted in their
    // own checkout, not the parent's.
    ".claude/worktrees/**",
    ".worktrees/**",
    "docs/design/**",
    "ios/**",
    "android/**",
    "build/**",
    "**/node_modules/**"
  ]
}
